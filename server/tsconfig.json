{
    "compilerOptions": {
        "rootDir": "./src", 
    "outDir": "./dist",
        "declaration": true,
        "declarationMap": true,
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "strict": true,

        "paths": {
            "@/generated": ["./generated/prisma"],
            "@/generated/*": ["./generated/prisma/*"]
        }
    },
    "include": ["./src/**/*"],
    "exclude": ["node_modules", "dist"]
}